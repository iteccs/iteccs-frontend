<style>

/* =====================
GLOBAL
===================== */

body{
font-family:"Inter",system-ui;
margin:0;
background:#f4f7fb;
color:#0f172a;
line-height:1.7;
}

/* =====================
HERO
===================== */

.program-hero{
padding:110px 20px 90px;
background:linear-gradient(135deg,#020617,#07101f,#0b2a5b);
color:white;
text-align:center;
}

.program-hero h1{
font-size:3rem;
font-weight:900;
margin-bottom:20px;
}

.program-hero p{
max-width:900px;
margin:auto;
font-size:1.2rem;
opacity:.95;
}

.hero-divider{
width:80px;
height:4px;
background:#FDB515;
margin:25px auto;
border-radius:999px;
}

/* =====================
SECTION
===================== */

.section{
padding:80px 20px;
max-width:1200px;
margin:auto;
}

/* =====================
CARD GRID
===================== */

.card-grid{
display:grid;
grid-template-columns:repeat(3,1fr);
gap:26px;
margin-top:40px;
}

.card{
background:white;
padding:26px;
border-radius:16px;
box-shadow:0 20px 60px rgba(0,0,0,.08);
transition:.3s;
}

.card:hover{
transform:translateY(-8px);
box-shadow:0 40px 100px rgba(0,0,0,.18);
}

.card h3{
color:#0b2a5b;
font-weight:800;
}

.card p,
.card ul{
color:#475569;
}

.card i{
color:#FDB515;
margin-right:8px;
}

/* =====================
HEADINGS
===================== */

.section-title{
text-align:center;
font-size:2.2rem;
font-weight:900;
margin-top:60px;
}

/* =====================
CTA
===================== */

.cta{
background:#020617;
color:white;
padding:80px 20px;
text-align:center;
margin-top:60px;
}

.cta h2{
font-size:2rem;
}

.cta p{
max-width:800px;
margin:auto;
opacity:.95;
}

/* =====================
RESPONSIVE
===================== */

@media(max-width:1000px){

.card-grid{
grid-template-columns:repeat(2,1fr);
}

.program-hero h1{
font-size:2.2rem;
}

}

@media(max-width:700px){

.card-grid{
grid-template-columns:1fr;
}

}

</style>

